# 服务器配置
PORT=5000
NODE_ENV=development

# 数据库配置
MONGODB_URI=mongodb://localhost:27017/ai-hotspot-monitor

# JWT配置
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRE=24h

# AI服务配置 - 支持多个AI提供商
# GLM配置（默认，推荐）
AI_SERVICE_PROVIDER=glm
GLM_API_KEY=your-glm-api-key-here
GLM_API_URL=https://new-api-test.igancao.cn/v1/chat/completions
GLM_MODEL=glm-4.7

# OpenRouter配置（备用）
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_REFERER=http://localhost:3000
OPENROUTER_TITLE=AI Hotspot Monitor
OPENROUTER_MODEL=openai/gpt-4o

# DeepSeek配置（备用）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REFERER=http://localhost:3000
DEEPSEEK_TITLE=AI Hotspot Monitor

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password
SMTP_FROM=AI Hotspot Monitor <noreply@yourdomain.com>

# 爬虫配置
CRAWLER_INTERVAL=30m
MAX_CRAWL_THREADS=5
CRAWLER_TIMEOUT=30000
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# 微博爬虫配置（需要登录Cookie）
WEIBO_COOKIE=
# 获取方式：登录微博后，从浏览器开发者工具中复制Cookie

# Bing搜索API配置（可选，使用API可获得更稳定的结果）
BING_API_KEY=
# 获取方式：https://www.microsoft.com/en-us/bing/apis/bing-web-search-api

# Twitter API配置（可选，需要付费API）
TWITTER_BEARER_TOKEN=
# 获取方式：https://developer.twitter.com/en/portal/dashboard

# Web推送配置
WEBPUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
WEBPUSH_EMAIL=support@yourdomain.com

# Slack配置
SLACK_ENABLED=false
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#hotspot-alerts

# 监控配置
MAX_HOTSPOTS_PER_SCAN=100
CONFIDENCE_THRESHOLD=70
AUTO_DELETE_HISTORY_DAYS=90
SCAN_INTERVAL_MINUTES=30

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL_SECONDS=600

# 开发调试
DEBUG=false
CORS_ORIGIN=http://localhost:3000